:80 {
    root * /srv
    encode gzip zstd
    header {
        # v0.9.1 — inline JS+CSS extracted to /v2/{styles.css,deck.js}; strict CSP restored. Trusted Types directive intentionally NOT re-added: v2 deck uses innerHTML for slide rendering (without a TT policy) — added back only after deck refactor to safe DOM APIs.
        # v0.10.2 — access=internal forward_auth gate (see handle block at bottom).
        Content-Security-Policy "default-src 'self'; script-src 'self'; style-src 'self'; img-src 'self' data:; font-src 'self'; connect-src 'self'; media-src 'self'; base-uri 'self'; form-action 'self'; object-src 'none'; frame-ancestors 'none'"
        X-Frame-Options "DENY"
        X-Content-Type-Options "nosniff"
        Referrer-Policy "strict-origin-when-cross-origin"
        Permissions-Policy "camera=(), microphone=(), geolocation=(), interest-cohort=(), accelerometer=(), autoplay=(), encrypted-media=(), gyroscope=(), magnetometer=(), midi=(), payment=(), usb=(), sync-xhr=()"
        X-Permitted-Cross-Domain-Policies "none"
        # Strict-Transport-Security, COOP, CORP emitted by host Caddy proxy via dokku caddy:labels:add
        -Server
    }

    handle /health {
        header Content-Type application/json
        respond "{\"status\":\"ok\",\"version\":\"0.10.2\"}" 200
    }
    handle /healthz {
        header Content-Type application/json
        respond "{\"status\":\"ok\",\"version\":\"0.10.2\"}" 200
    }
    handle /version {
        header Content-Type application/json
        respond `{"app":"presentation","version":"0.10.2","classification":"tool/public/active"}` 200
    }
    handle /robots.txt {
        header Content-Type "text/plain; charset=utf-8"
        header Cache-Control "public, max-age=3600"
        try_files /robots.txt =404
        file_server
    }
    handle /sitemap.xml {
        header Content-Type "application/xml; charset=utf-8"
        header Cache-Control "public, max-age=3600"
        try_files /sitemap.xml =404
        file_server
    }

    @static path_regexp static \.((jpg|jpeg|png|gif|svg|ico|css|js|woff2?|ttf|webmanifest|json))$
    header @static Cache-Control "public, max-age=86400"

    handle {
        # v0.10.2 — access=internal gate (SRcore #721). Verifies SSO cookie via
        # login.sardonicrepulsion.com/verify; unauth requests get 302 to login.
        # /health /healthz /version handled above so monitors stay public.
        #
        # The original host + uri travel as QUERY-STRING args (?h=, ?u=, ?p=)
        # rather than X-Forwarded-* headers because host-side Caddy strips
        # client-set X-Forwarded-* headers when the upstream is not in its
        # `trusted_proxies` list — so v0.10.2's header_up directives were
        # silently overwritten by the time /verify saw them. Query-string args
        # survive the proxy chain because they're part of the URL. login v1.3.0+
        # accepts these args and gates each candidate through validateRedirect().
        forward_auth login.sardonicrepulsion.com:443 {
            uri /verify?h={http.request.host}&u={http.request.uri.path}&p={http.request.scheme}
            transport http {
                tls
                tls_server_name login.sardonicrepulsion.com
            }
            copy_headers X-Auth-User X-Auth-Role
        }
        header Cache-Control "no-cache, must-revalidate"
        try_files {path} {path}/ =404
        file_server
    }

    handle_errors {
        @notfound expression {err.status_code} == 404
        rewrite @notfound /404.html
        file_server
    }
}
